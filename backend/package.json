{
  "name": "dsa-learning-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "migrate": "tsx src/db/runMigration.ts",
    "migrate:init": "tsx src/db/runMigration.ts 001_init.sql",
    "seed:admin": "node --env-file=.env --import tsx/esm src/db/seeds/seedAdmin.ts",
    "test:integration": "node --env-file=.env --import tsx/esm --test --test-reporter spec tests/01_health.test.ts tests/02_auth.test.ts tests/03_problems.test.ts tests/04_admin.test.ts tests/05_subscriptions.test.ts tests/06_execution.test.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2"
  }
}
